# ntfy.sh push notification settings for antcam.
# Copy to /etc/antcam/ntfy.env (systemd) or pass as --env-file to Docker.
#
# Notifications are sent when the detected count reaches NTFY_THRESHOLD.
# Priority escalates automatically with the count:
#   1–2 ants  → low
#   3–9 ants  → default
#   10+ ants  → high

# ntfy server — use https://ntfy.sh for the public instance, or your self-hosted URL
NTFY_URL=https://ntfy.sh

# Topic to publish to (unique, hard-to-guess name recommended on the public server)
NTFY_TOPIC=my-ant-sensor-abc123

# Minimum ant count that triggers a notification (set to 0 to always notify)
NTFY_THRESHOLD=1

# Authentication — choose one:
#   Token-based (recommended): set NTFY_TOKEN
#   Basic auth:                set NTFY_USER + NTFY_PASS
#   Public topic (no auth):    leave all three blank
NTFY_TOKEN=
NTFY_USER=
NTFY_PASS=
