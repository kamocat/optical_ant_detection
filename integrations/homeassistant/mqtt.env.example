# MQTT broker connection settings for antcam.
# Copy to /etc/antcam/mqtt.env (systemd) or pass as --env-file (Docker).
# Adjust the parameters to match your setup

MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=MY_USERNAME
MQTT_PASS=MY_PASSWORD
MQTT_TOPIC=home/kitchen/ants

# IP camera stream URL
CAM_URL=http://192.168.1.209:8080
